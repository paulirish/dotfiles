{
  "compilerOptions": {
    "target": "esnext",
    "module": "preserve",
    "moduleResolution": "bundler",

    "noEmit": true,
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "skipLibCheck": true,

    "lib": ["esnext", "dom", "dom.iterable"]
  },
  "include": ["src/**/*", "tests/**/*", "*.js"]
}
