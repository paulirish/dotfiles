{
  "name": "@paulirish/agents",
  "version": "0.1.0",
  "description": "A monorepo for Paul Irish's Gemini skills and CLI agents.",
  "type": "module",
  "private": true,
  "bin": {
    "heap-snapshot": "./clis/heap-snapshot-cli/bin/heap-snapshot.js"
  },
  "engines": {
    "node": ">=24.11.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test:distill": "node --test \"skills/distill-page/test/!(*cdp).test.ts\" && node --test skills/distill-page/test/cdp.test.ts && node --test skills/distill-page/test/turndown-cdp.test.ts",
    "test": "pnpm run test:distill && pnpm --filter !turndown -r run test",
    "preflight": "pnpm typecheck && pnpm test"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.12.1",
    "heap-snapshot-toolkit": "^1.1.3",
    "markpaste": "^0.0.6",
    "playwright": "^1.61.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.5",
    "typescript": "^5.8.2"
  }
}
