#!/bin/bash

# archive-merged-branches.sh
#
# HOW IT WORKS:
# 1. Standard Merges: Uses `git branch --merged` to find branches already part of the
#    main branch's history.
#
# 2. Squashed Merges (via git patch-id):
#    When you "Squash and Merge" on GitHub, the branch's individual commits are lost,
#    and a new commit is created on main. Standard git merge checks fail here.
#    `git patch-id` generates a stable SHA-1 hash of a diff, ignoring metadata like
#    commit dates or whitespace-only changes.
#
#    The script:
#    a) Caches patch-ids for the last 1000 commits on main.
#    b) Calculates the patch-id of the *entire* candidate branch (diff from merge-base).
#    c) If the branch's patch-id matches a commit's patch-id on main, the content
#       is identical, meaning it was squashed and merged.

DRYRUN=0

MAIN_BRANCH=$(git remote show origin | grep "HEAD branch" | sed 's/.*: //')
if [ -z "$MAIN_BRANCH" ]; then
    MAIN_BRANCH="main"
fi

echo "Using main branch: $MAIN_BRANCH"

# Get all local branches except the main one and the current one
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
BRANCHES=$(git branch --format="%(refname:short)" | grep -v "^$MAIN_BRANCH$" | grep -v "^$CURRENT_BRANCH$")

if [ -z "$BRANCHES" ]; then
    echo "No other local branches found."
    exit 0
fi

echo "Scanning branches for merge status... this may take a moment."

# Pre-calculate patch-ids for recent commits in main to speed up squashed detection
PATCH_CACHE=$(mktemp)
echo "Caching patch-ids from $MAIN_BRANCH..."
git log -p $MAIN_BRANCH -n 1000 | git patch-id > "$PATCH_CACHE"

CANDIDATES=()

# First, collect candidates with their commit timestamps for sorting
TEMP_CANDIDATES=$(mktemp)

for branch in $BRANCHES; do
    # Check if fully merged
    REASON=""
    if git branch --merged "$MAIN_BRANCH" | grep -qE "^\s*\*?\s*$branch$"; then
        REASON="(merged)"
    else
        # Check if squashed
        BASE=$(git merge-base "$MAIN_BRANCH" "$branch" 2>/dev/null)
        if [ -n "$BASE" ]; then
            BRANCH_PATCH_ID=$(git diff "$BASE..$branch" | git patch-id | awk '{print $1}')
            if [ -n "$BRANCH_PATCH_ID" ]; then
                MATCHING_COMMIT=$(grep "^$BRANCH_PATCH_ID" "$PATCH_CACHE" | head -n 1 | awk '{print $2}')
                if [ -n "$MATCHING_COMMIT" ]; then
                    REASON="(squashed into ${MATCHING_COMMIT:0:7})"
                fi
            fi
        fi
    fi

    if [ -n "$REASON" ]; then
        # Get unix timestamp for sorting
        TIMESTAMP=$(git log -1 --format="%at" "$branch")
        echo "$TIMESTAMP $branch $REASON" >> "$TEMP_CANDIDATES"
    fi
done

rm "$PATCH_CACHE"

# Sort by timestamp descending and read into CANDIDATES array
if [ -s "$TEMP_CANDIDATES" ]; then
    while read -r line; do
        # Strip the timestamp for the final display
        CANDIDATES+=("$(echo "$line" | cut -d' ' -f2-)")
    done < <(sort -rn "$TEMP_CANDIDATES")
fi
rm "$TEMP_CANDIDATES"

if [ ${#CANDIDATES[@]} -eq 0 ]; then
    echo "No merged or squashed branches found."
    exit 0
fi

# Define colors
CYAN=$(printf '\033[0;36m')
YELLOW=$(printf '\033[1;33m')
GRAY=$(printf '\033[0;90m')
NC=$(printf '\033[0m') # No Color

echo ""
echo "Found ${#CANDIDATES[@]} candidate branches for archiving:"
for i in "${!CANDIDATES[@]}"; do
    entry="${CANDIDATES[$i]}"
    branch=$(echo "$entry" | awk '{print $1}')
    reason=$(echo "$entry" | cut -d' ' -f2-)

    # Get branch details: date (relative) and subject
    # We use a custom format to extract them separately for easier coloring
    rel_date=$(git log -1 --format="%ar" "$branch")
    subject=$(git log -1 --format="%s" "$branch")

    # Define green for the date
    GREEN=$(printf '\033[0;32m')

    # Use %b for all fields containing escape codes
    printf "%2d) %b%-30s%b %b%-30s%b %b%-15s%b %s\n" \
        "$((i+1))" \
        "$CYAN" "$branch" "$NC" \
        "$YELLOW" "$reason" "$NC" \
        "$GREEN" "$rel_date" "$NC" \
        "$subject"
done
echo ""

if [ "$DRYRUN" = "1" ]; then
    printf "${YELLOW}DRY RUN MODE ENABLED.${NC} No changes will be made.\n"
fi

printf "Archive all these as tags and delete the branches? [y/N] "
read -r response

if [[ "$response" =~ ^[Yy]$ ]]; then
    for entry in "${CANDIDATES[@]}"; do
        branch=$(echo "$entry" | awk '{print $1}')
        TAG_NAME="archived/$branch"

        # Check if tag already exists, if so append a timestamp
        if git rev-parse "$TAG_NAME" >/dev/null 2>&1; then
            TAG_NAME="${TAG_NAME}-$(date +%s)"
        fi

        if [ "$DRYRUN" = "1" ]; then
            echo -e "${GRAY}[DRY RUN] Would create tag $TAG_NAME and delete $branch${NC}"
        else
            echo "Archiving $branch..."
            # Create a lightweight tag so it isn't automatically pushed by followTags
            git tag "$TAG_NAME" "$branch" > /dev/null

            # Handle worktree if branch is in use
            WORKTREE_PATH=$(git worktree list --porcelain | grep -B 2 "branch refs/heads/$branch$" | grep "^worktree " | head -n 1 | cut -d' ' -f2-)
            if [ -n "$WORKTREE_PATH" ]; then
                # Check for uncommitted changes in the worktree
                if [ -n "$(git -C "$WORKTREE_PATH" status --porcelain)" ]; then
                    echo -e "${YELLOW}Skipping $branch: Worktree at $WORKTREE_PATH has uncommitted changes.${NC}"
                    continue
                fi
                echo "Removing worktree at $WORKTREE_PATH..."
                git worktree remove "$WORKTREE_PATH"
            fi

            git branch -D "$branch"
        fi
    done

    # Clean up stale worktree information
    git worktree prune
else
    echo "Aborted."
fi

echo "Done."
