#!/usr/bin/env node --experimental-strip-types
import { fetchAsMarkdown } from '../personal_mcp/tools.ts';

const result = await fetchAsMarkdown({ url: process.argv[2] });

if (result.isError) {
  console.error('Error:', result.content[0].text);
  process.exit(1);
}

process.stdout.write(result.content[0].text);


